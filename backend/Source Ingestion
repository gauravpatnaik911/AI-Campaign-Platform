{"cells":[{"cell_type":"code","source":"\"\"\"\nMaps to 02_Source_Ingestion workflow.\nHandles file logic, metadata stripping, and CSV normalization.\n\"\"\"\n\nimport csv\nimport io\n\ndef parse_file(f) -> tuple[str, str]:\n    \"\"\"Extracts raw text/signal data from uploaded multimodal artifacts.\"\"\"\n    name = f.name.lower()\n    if name.endswith((\".png\", \".jpg\", \".jpeg\")):\n        return \"\", \"image\"\n    if name.endswith(\".csv\"):\n        try:\n            content = f.read().decode(\"utf-8\", errors=\"ignore\")\n            rows = [\", \".join(r) for r in csv.reader(io.StringIO(content))]\n            return \"\\n\".join(rows[:120]), \"csv\"\n        except Exception:\n            return \"\", \"csv\"\n    if name.endswith(\".txt\"):\n        return f.read().decode(\"utf-8\", errors=\"ignore\")[:4000], \"txt\"\n    return \"\", \"unknown\"","outputs":[],"execution_count":null,"metadata":{}}],"metadata":{"colab":{"from_bard":true},"kernelspec":{"display_name":"Python 3","name":"python3"}},"nbformat":4,"nbformat_minor":0}